# App
NODE_ENV=development
PORT=3001
FRONTEND_URL=http://localhost:5173
SESSION_SECRET=replace-with-long-random-string
ENCRYPTION_KEY=replace-with-64-char-hex-openssl-rand-hex-32

# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/ai_coo

# Google OAuth (same client for auth + APIs)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:3001/auth/google/callback
GOOGLE_CONNECT_REDIRECT_URI=http://localhost:3001/connections/google/callback

# Slack
SLACK_CLIENT_ID=
SLACK_CLIENT_SECRET=
SLACK_REDIRECT_URI=http://localhost:3001/connections/slack/callback

# Asana
ASANA_CLIENT_ID=
ASANA_CLIENT_SECRET=
ASANA_REDIRECT_URI=http://localhost:3001/connections/asana/callback

# OpenRouter
OPENROUTER_API_KEY=
OPENROUTER_MODEL=openai/gpt-4o-mini
OPENROUTER_TEMPERATURE=0.3
OPENROUTER_MAX_TOKENS=1500

# Email (Resend)
RESEND_API_KEY=
EMAIL_FROM=AI COO <onboarding@resend.dev>
